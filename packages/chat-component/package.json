{
  "name": "@edjbarron/netapp-chat-component",
  "version": "0.1.5",
  "description": "React chat UI component for the netapp-chat-service agentic chat backend (LLM + MCP tool routing).",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "dev": "vite build --watch",
    "build": "tsc --noEmit && vite build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ebarron/netapp-chat-service.git",
    "directory": "packages/chat-component"
  },
  "homepage": "https://github.com/ebarron/netapp-chat-service/tree/main/packages/chat-component#readme",
  "bugs": {
    "url": "https://github.com/ebarron/netapp-chat-service/issues"
  },
  "keywords": [
    "react",
    "chat",
    "chatbot",
    "llm",
    "mcp",
    "agent",
    "mantine",
    "netapp"
  ],
  "author": "ebarron",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "@mantine/charts": "^8.0.0 || ^9.0.0",
    "@mantine/core": "^8.0.0 || ^9.0.0",
    "@mantine/hooks": "^8.0.0 || ^9.0.0",
    "@tabler/icons-react": "^3.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "react-markdown": "^9.0.0",
    "recharts": "^3.0.0",
    "remark-gfm": "^4.0.0"
  },
  "devDependencies": {
    "@mantine/charts": "^8.3.12",
    "@mantine/core": "^8.3.12",
    "@mantine/hooks": "^8.3.12",
    "@tabler/icons-react": "^3.36.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.8",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.2",
    "happy-dom": "^20.8.9",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "typescript": "^5.9.0",
    "vite": "^7.0.0",
    "vite-plugin-dts": "^4.5.0",
    "vitest": "^4.0.0"
  }
}
